# ClawScale Environment Configuration
# Copy this file to .env and fill in values

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://clawscale:clawscale@localhost:5432/clawscale

# ─── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
COKE_JWT_SECRET=change-me-to-a-different-long-random-string

# ─── API Server ────────────────────────────────────────────────────────────────
PORT=4041
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:4040
DOMAIN_CLIENT=http://localhost:4040

# ─── OpenClaw Bridge ───────────────────────────────────────────────────────────
# Path to the OpenClaw binary (if running locally alongside ClawScale)
OPENCLAW_BIN=openclaw
# ClawScale spawns per-tenant OpenClaw gateway instances; their ports are
# assigned dynamically starting from this base.
OPENCLAW_PORT_BASE=19000
# Directory where per-tenant OpenClaw data is stored
OPENCLAW_DATA_DIR=./data/tenants

# ─── Web (frontend) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4041
NEXT_PUBLIC_COKE_API_URL=http://localhost:4041

# ─── Coke Email Delivery ───────────────────────────────────────────────────────
# Prefer Mailgun when both variables are present. Otherwise SMTP is used.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
EMAIL_FROM=noreply@coke.app
EMAIL_FROM_NAME=Coke

# SMTP fallback
EMAIL_SERVICE=
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_ENCRYPTION=starttls
EMAIL_ENCRYPTION_HOSTNAME=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_ALLOW_SELFSIGNED=false

# ─── Coke Payments ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

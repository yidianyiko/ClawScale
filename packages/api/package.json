{
  "name": "@clawscale/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "coke:stripe:smoke": "tsx src/scripts/stripe-e2e-smoke.ts",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "platformization:audit": "tsx src/scripts/audit-platformization-baseline.ts",
    "platformization:backfill": "tsx src/scripts/backfill-platformization-identity.ts",
    "platformization:verify": "tsx src/scripts/verify-platformization-migration.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@clawscale/shared": "workspace:*",
    "@grammyjs/runner": "^2.0.3",
    "@hapi/boom": "9.1.4",
    "@hono/node-server": "^1.14.3",
    "@hono/zod-validator": "^0.4.3",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@line/bot-sdk": "^10.6.0",
    "@prisma/client": "^6.6.0",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.15.0",
    "@wecom/aibot-node-sdk": "^1.0.4",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "bcryptjs": "^3.0.2",
    "discord.js": "^14.25.1",
    "dotenv": "^16.5.0",
    "grammy": "^1.41.1",
    "hono": "^4.7.10",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.2.37",
    "matrix-js-sdk": "^41.2.0",
    "nanoid": "^5.1.5",
    "openai": "^6.33.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "resend": "^4.6.0",
    "slugify": "^1.6.6",
    "stripe": "^22.0.1",
    "ws": "^8.20.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "playwright": "^1.59.1",
    "prisma": "^6.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum MemberRole {
  admin
  member
  viewer
}

enum ChannelStatus {
  connected
  disconnected
  pending
  error
  archived
}

enum ChannelScope {
  tenant_shared
  personal
}

enum ChannelType {
  whatsapp
  telegram
  slack
  discord
  instagram
  facebook
  line
  signal
  teams
  matrix
  web
  wechat_work
  whatsapp_business
  wechat_personal
}

enum WorkflowType {
  script_js
  script_python
  script_shell
  n8n
  pulse_editor
}

enum MessageRole {
  user
  assistant
}

enum EndUserStatus {
  allowed
  blocked
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Tenant {
  id        String     @id
  slug      String     @unique
  name      String
  settings  Json       @default("{}")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  members       Member[]
  sessions      Session[]
  channels      Channel[]
  endUsers      EndUser[]
  clawscaleUsers ClawscaleUser[]
  workflows     Workflow[]
  auditLogs     AuditLog[]
  aiBackends    AiBackend[]

  @@map("tenants")
}

/// Internal staff who manage the bot (owner/admin/viewers).
model Member {
  id           String     @id
  tenantId     String     @map("tenant_id")
  email        String
  name         String
  passwordHash String     @map("password_hash")
  role         MemberRole @default(member)
  isActive     Boolean    @default(true) @map("is_active")
  lastActiveAt DateTime?  @map("last_active_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions  Session[]
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("members")
}

model Session {
  id        String   @id
  memberId  String   @map("member_id")
  tenantId  String   @map("tenant_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([tenantId])
  @@map("sessions")
}

model Channel {
  id                   String        @id
  tenantId             String        @map("tenant_id")
  type                 ChannelType
  scope                ChannelScope   @default(tenant_shared)
  ownerClawscaleUserId String?       @map("owner_clawscale_user_id")
  activeLifecycleKey   String?       @unique @map("active_lifecycle_key")
  name                 String
  status               ChannelStatus @default(disconnected)
  config               Json          @default("{}")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerClawscaleUser ClawscaleUser? @relation(fields: [ownerClawscaleUserId], references: [id], onDelete: SetNull)
  conversations     Conversation[]
  endUsers          EndUser[]

  @@index([tenantId])
  @@index([ownerClawscaleUserId])
  @@map("channels")
}

/// External users who chat with the bot via social channels.
/// Identified by (tenantId, channelId, externalId) — the platform's user ID.
/// Can be anonymous (no name/email) until the bot or owner enriches the record.
model EndUser {
  id         String        @id
  tenantId   String        @map("tenant_id")
  channelId  String        @map("channel_id")
  externalId String        @map("external_id") // platform-native user ID
  name       String?
  email      String?
  metadata   Json          @default("{}")
  status     EndUserStatus @default(allowed)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  /// When set, this EndUser defers to the primary EndUser for cross-channel identity.
  linkedTo      String?   @map("linked_to")
  clawscaleUserId String? @map("clawscale_user_id")

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel         Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  linkedPrimary   EndUser?       @relation("EndUserLink", fields: [linkedTo], references: [id], onDelete: SetNull)
  linkedFrom      EndUser[]      @relation("EndUserLink")
  clawscaleUser   ClawscaleUser? @relation(fields: [clawscaleUserId], references: [id], onDelete: SetNull)
  conversations   Conversation[]
  activeBackends  EndUserBackend[]
  linkCodes       LinkCode[]

  @@unique([tenantId, channelId, externalId])
  @@index([clawscaleUserId])
  @@index([tenantId])
  @@map("end_users")
}

model ClawscaleUser {
  id            String   @id
  tenantId      String   @map("tenant_id")
  cokeAccountId String   @map("coke_account_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endUsers EndUser[]

  @@unique([tenantId, cokeAccountId])
  @@index([tenantId])
  @@map("clawscale_users")
}

/// Many-to-many join: which AI backends an end-user has active in their session.
model EndUserBackend {
  endUserId String   @map("end_user_id")
  backendId String   @map("backend_id")
  addedAt   DateTime @default(now()) @map("added_at")

  endUser   EndUser   @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  backend   AiBackend @relation(fields: [backendId], references: [id], onDelete: Cascade)

  @@id([endUserId, backendId])
  @@index([endUserId])
  @@index([backendId])
  @@map("end_user_backends")
}

model Conversation {
  id        String   @id
  tenantId  String   @map("tenant_id")
  channelId String   @map("channel_id")
  endUserId String   @map("end_user_id")
  backendId String?  @map("backend_id")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  channel  Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  endUser  EndUser    @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  backend  AiBackend? @relation(fields: [backendId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([tenantId])
  @@index([endUserId])
  @@map("conversations")
}

model Message {
  id             String      @id
  conversationId String      @map("conversation_id")
  role           MessageRole
  content        String
  /// Which AI backend generated this assistant message (null for user messages & ClawScale agent)
  backendId      String?     @map("backend_id")
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  backend      AiBackend?   @relation(fields: [backendId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@map("messages")
}

/// Admin-configured AI providers. End-users pick one at the start of a conversation.
/// Many-to-many with EndUser (via selectedBackend) and Conversation (via backendId).
model AiBackend {
  id        String   @id
  tenantId  String   @map("tenant_id")
  /// Human-readable name shown to end-users in the selection menu
  name      String
  /// Provider type: openai | anthropic | openrouter | pulse | openclaw | custom
  type      String
  /// Provider-specific config: { apiKey?, model?, baseUrl?, pulseApiUrl?, openClawUrl? }
  config    Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// True for the built-in ClawScale default agent (one per tenant, cannot be deleted)
  isDefault     Boolean  @default(false) @map("is_default")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endUsers      EndUserBackend[]
  conversations Conversation[]
  messages      Message[]

  @@index([tenantId])
  @@map("ai_backends")
}

/// Owner-defined automations that the AI agent can invoke during a conversation.
model Workflow {
  id          String       @id
  tenantId    String       @map("tenant_id")
  name        String
  description String?
  type        WorkflowType
  /// For script types: the script source code.
  /// For n8n/pulse_editor: not used (use config instead).
  code        String?
  /// For n8n: { webhookUrl, method, headers }
  /// For pulse_editor: { appId, skillName }
  /// For scripts: optional env/args config
  config      Json         @default("{}")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("workflows")
}

model AuditLog {
  id         String   @id
  tenantId   String   @map("tenant_id")
  memberId   String?  @map("member_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("audit_logs")
}

/// Short-lived codes for cross-channel account linking.
model LinkCode {
  id        String   @id @default(cuid())
  code      String   @unique
  tenantId  String   @map("tenant_id")
  endUserId String   @map("end_user_id")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  endUser EndUser @relation(fields: [endUserId], references: [id], onDelete: Cascade)

  @@index([code, used])
  @@map("link_codes")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum MemberRole {
  admin
  member
  viewer
}

enum ChannelStatus {
  connected
  disconnected
  pending
  error
  archived
}

enum ChannelScope {
  tenant_shared
  personal
}

enum ChannelType {
  whatsapp
  telegram
  slack
  discord
  instagram
  facebook
  line
  signal
  teams
  matrix
  web
  wechat_work
  whatsapp_business
  wechat_personal
}

enum WorkflowType {
  script_js
  script_python
  script_shell
  n8n
  pulse_editor
}

enum MessageRole {
  user
  assistant
}

enum EndUserStatus {
  allowed
  blocked
}

enum CokeAccountStatus {
  normal
  suspended
}

enum VerifyTokenType {
  email_verify
  password_reset
}

enum IdentityClaimStatus {
  active
  unclaimed
  pending
}

enum CustomerKind {
  personal
  organization
}

enum MembershipRole {
  owner
  member
  viewer
}

enum AgentBindingProvisionStatus {
  pending
  ready
  error
}

enum ChannelOwnershipKind {
  customer
  shared
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Tenant {
  id        String     @id
  slug      String     @unique
  name      String
  settings  Json       @default("{}")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  members       Member[]
  sessions      Session[]
  channels      Channel[]
  endUsers      EndUser[]
  clawscaleUsers ClawscaleUser[]
  workflows     Workflow[]
  auditLogs     AuditLog[]
  aiBackends    AiBackend[]
  deliveryRoutes DeliveryRoute[]

  @@map("tenants")
}

/// Internal staff who manage the bot (owner/admin/viewers).
model Member {
  id           String     @id
  tenantId     String     @map("tenant_id")
  email        String
  name         String
  passwordHash String     @map("password_hash")
  role         MemberRole @default(member)
  isActive     Boolean    @default(true) @map("is_active")
  lastActiveAt DateTime?  @map("last_active_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions  Session[]
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("members")
}

model AdminAccount {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  mfaSecret    String?  @map("mfa_secret")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_accounts")
}

model Session {
  id        String   @id
  memberId  String   @map("member_id")
  tenantId  String   @map("tenant_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([tenantId])
  @@map("sessions")
}

model Channel {
  id                   String        @id
  tenantId             String        @map("tenant_id")
  type                 ChannelType
  scope                ChannelScope   @default(tenant_shared)
  ownershipKind        ChannelOwnershipKind @default(customer) @map("ownership_kind")
  customerId           String?       @map("customer_id")
  agentId              String?       @map("agent_id")
  ownerClawscaleUserId String?       @map("owner_clawscale_user_id")
  activeLifecycleKey   String?       @unique @map("active_lifecycle_key")
  name                 String
  status               ChannelStatus @default(disconnected)
  config               Json          @default("{}")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer           Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  agent              Agent?          @relation(fields: [agentId], references: [id], onDelete: SetNull)
  ownerClawscaleUser ClawscaleUser? @relation(fields: [ownerClawscaleUserId], references: [id], onDelete: SetNull)
  externalIdentities ExternalIdentity[]
  conversations     Conversation[]
  endUsers          EndUser[]
  deliveryRoutes    DeliveryRoute[]

  @@index([tenantId])
  @@index([customerId])
  @@index([agentId])
  @@index([ownerClawscaleUserId])
  @@map("channels")
}

/// External users who chat with the bot via social channels.
/// Identified by (tenantId, channelId, externalId) — the platform's user ID.
/// Can be anonymous (no name/email) until the bot or owner enriches the record.
model EndUser {
  id         String        @id
  tenantId   String        @map("tenant_id")
  channelId  String        @map("channel_id")
  externalId String        @map("external_id") // platform-native user ID
  name       String?
  email      String?
  metadata   Json          @default("{}")
  status     EndUserStatus @default(allowed)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  /// When set, this EndUser defers to the primary EndUser for cross-channel identity.
  linkedTo      String?   @map("linked_to")
  clawscaleUserId String? @map("clawscale_user_id")

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel         Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  linkedPrimary   EndUser?       @relation("EndUserLink", fields: [linkedTo], references: [id], onDelete: SetNull)
  linkedFrom      EndUser[]      @relation("EndUserLink")
  clawscaleUser   ClawscaleUser? @relation(fields: [clawscaleUserId], references: [id], onDelete: SetNull)
  conversations   Conversation[]
  activeBackends  EndUserBackend[]
  linkCodes       LinkCode[]
  deliveryRoutes  DeliveryRoute[]

  @@unique([tenantId, channelId, externalId])
  @@index([clawscaleUserId])
  @@index([tenantId])
  @@map("end_users")
}

model ClawscaleUser {
  id            String   @id
  tenantId      String   @map("tenant_id")
  cokeAccountId String   @map("coke_account_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account       CokeAccount @relation(fields: [cokeAccountId], references: [id], onDelete: Cascade)
  channels      Channel[]
  endUsers      EndUser[]
  deliveryRoutes DeliveryRoute[]
  conversations Conversation[]

  @@unique([tenantId, cokeAccountId])
  @@unique([cokeAccountId])
  @@index([tenantId])
  @@map("clawscale_users")
}

model CokeAccount {
  id            String            @id @default(cuid())
  email         String            @unique
  passwordHash  String            @map("password_hash")
  displayName   String            @map("display_name")
  emailVerified Boolean           @default(false) @map("email_verified")
  status        CokeAccountStatus @default(normal)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  clawscaleUser  ClawscaleUser?
  subscriptions  Subscription[]
  verifyTokens   VerifyToken[]

  @@map("coke_accounts")
}

model Identity {
  id                 String              @id
  email              String              @unique
  displayName        String              @map("display_name")
  claimStatus        IdentityClaimStatus @default(unclaimed) @map("claim_status")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  memberships        Membership[]
  externalIdentities ExternalIdentity[]

  @@map("identities")
}

model Customer {
  id           String       @id
  kind         CustomerKind @default(personal)
  displayName  String       @map("display_name")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  memberships  Membership[]
  channels     Channel[]
  agentBindings AgentBinding[]

  @@map("customers")
}

model Membership {
  id         String         @id
  identityId String         @map("identity_id")
  customerId String         @map("customer_id")
  role       MembershipRole @default(member)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([identityId, customerId])
  @@index([identityId])
  @@index([customerId])
  @@map("memberships")
}

model Agent {
  id         String   @id
  slug       String   @unique
  name       String
  endpoint   String
  authToken  String   @map("auth_token")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  bindings AgentBinding[]
  channels Channel[]

  @@map("agents")
}

model AgentBinding {
  id                 String                       @id @default(cuid())
  customerId         String                       @map("customer_id")
  agentId            String                       @map("agent_id")
  provisionStatus    AgentBindingProvisionStatus  @default(pending) @map("provision_status")
  provisionAttempts  Int                          @default(0) @map("provision_attempts")
  provisionLastError String?                      @map("provision_last_error")
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  agent    Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([customerId, agentId])
  @@index([customerId])
  @@index([agentId])
  @@map("agent_bindings")
}

model ExternalIdentity {
  id         String   @id
  identityId String   @map("identity_id")
  channelId  String?  @map("channel_id")
  provider   String
  externalId String   @map("external_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  channel  Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@unique([provider, externalId])
  @@index([identityId])
  @@index([channelId])
  @@map("external_identities")
}

model Subscription {
  id             String   @id @default(cuid())
  cokeAccountId   String   @map("coke_account_id")
  stripeSessionId String   @unique @map("stripe_session_id")
  amountPaid      Int      @map("amount_paid")
  currency        String   @default("usd")
  startsAt        DateTime @map("starts_at")
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  account CokeAccount @relation(fields: [cokeAccountId], references: [id], onDelete: Cascade)

  @@index([cokeAccountId])
  @@index([cokeAccountId, expiresAt])
  @@map("subscriptions")
}

model VerifyToken {
  id            String          @id @default(cuid())
  cokeAccountId String          @map("coke_account_id")
  tokenHash     String          @unique @map("token_hash")
  type          VerifyTokenType
  expiresAt     DateTime        @map("expires_at")
  used          Boolean         @default(false)
  createdAt     DateTime        @default(now()) @map("created_at")

  account CokeAccount @relation(fields: [cokeAccountId], references: [id], onDelete: Cascade)

  @@index([cokeAccountId])
  @@map("verify_tokens")
}

/// Many-to-many join: which AI backends an end-user has active in their session.
model EndUserBackend {
  endUserId String   @map("end_user_id")
  backendId String   @map("backend_id")
  addedAt   DateTime @default(now()) @map("added_at")

  endUser   EndUser   @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  backend   AiBackend @relation(fields: [backendId], references: [id], onDelete: Cascade)

  @@id([endUserId, backendId])
  @@index([endUserId])
  @@index([backendId])
  @@map("end_user_backends")
}

model Conversation {
  id        String   @id
  tenantId  String   @map("tenant_id")
  channelId String   @map("channel_id")
  endUserId String   @map("end_user_id")
  clawscaleUserId String? @map("clawscale_user_id")
  backendId String?  @map("backend_id")
  businessConversationKey String? @map("business_conversation_key")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  channel  Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  endUser  EndUser    @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  clawscaleUser ClawscaleUser? @relation(fields: [clawscaleUserId], references: [id], onDelete: SetNull)
  backend  AiBackend? @relation(fields: [backendId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([tenantId])
  @@index([endUserId])
  @@index([clawscaleUserId])
  @@unique([clawscaleUserId, businessConversationKey])
  @@map("conversations")
}

model DeliveryRoute {
  tenantId                String   @map("tenant_id")
  cokeAccountId           String   @map("coke_account_id")
  businessConversationKey String   @map("business_conversation_key")
  channelId               String   @map("channel_id")
  endUserId               String   @map("end_user_id")
  externalEndUserId       String   @map("external_end_user_id")
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel       Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  endUser       EndUser       @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  clawscaleUser ClawscaleUser @relation(fields: [cokeAccountId], references: [cokeAccountId], onDelete: Cascade)

  @@id([cokeAccountId, businessConversationKey])
  @@index([tenantId])
  @@index([channelId])
  @@index([endUserId])
  @@map("delivery_routes")
}

model Message {
  id             String      @id
  conversationId String      @map("conversation_id")
  role           MessageRole
  content        String
  /// Which AI backend generated this assistant message (null for user messages & ClawScale agent)
  backendId      String?     @map("backend_id")
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  backend      AiBackend?   @relation(fields: [backendId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@map("messages")
}

model OutboundDelivery {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  channelId      String   @map("channel_id")
  idempotencyKey String   @map("idempotency_key")
  payload        Json
  status         String
  error          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([idempotencyKey])
  @@index([tenantId])
  @@index([channelId])
  @@map("outbound_deliveries")
}

/// Admin-configured AI providers. End-users pick one at the start of a conversation.
/// Many-to-many with EndUser (via selectedBackend) and Conversation (via backendId).
model AiBackend {
  id        String   @id
  tenantId  String   @map("tenant_id")
  /// Human-readable name shown to end-users in the selection menu
  name      String
  /// Provider type: openai | anthropic | openrouter | pulse | openclaw | custom
  type      String
  /// Provider-specific config: { apiKey?, model?, baseUrl?, pulseApiUrl?, openClawUrl? }
  config    Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// True for the built-in ClawScale default agent (one per tenant, cannot be deleted)
  isDefault     Boolean  @default(false) @map("is_default")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endUsers      EndUserBackend[]
  conversations Conversation[]
  messages      Message[]

  @@index([tenantId])
  @@map("ai_backends")
}

/// Owner-defined automations that the AI agent can invoke during a conversation.
model Workflow {
  id          String       @id
  tenantId    String       @map("tenant_id")
  name        String
  description String?
  type        WorkflowType
  /// For script types: the script source code.
  /// For n8n/pulse_editor: not used (use config instead).
  code        String?
  /// For n8n: { webhookUrl, method, headers }
  /// For pulse_editor: { appId, skillName }
  /// For scripts: optional env/args config
  config      Json         @default("{}")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("workflows")
}

model AuditLog {
  id         String   @id
  tenantId   String   @map("tenant_id")
  memberId   String?  @map("member_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("audit_logs")
}

/// Short-lived codes for cross-channel account linking.
model LinkCode {
  id        String   @id @default(cuid())
  code      String   @unique
  tenantId  String   @map("tenant_id")
  endUserId String   @map("end_user_id")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  endUser EndUser @relation(fields: [endUserId], references: [id], onDelete: Cascade)

  @@index([code, used])
  @@map("link_codes")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum MemberRole {
  admin
  member
  viewer
}

enum ChannelStatus {
  connected
  disconnected
  pending
  error
  archived
}

enum ChannelScope {
  tenant_shared
  personal
}

enum ChannelType {
  whatsapp
  telegram
  slack
  discord
  instagram
  facebook
  line
  signal
  teams
  matrix
  web
  wechat_work
  whatsapp_business
  whatsapp_evolution
  wechat_personal
}

enum MessageRole {
  user
  assistant
}

enum EndUserStatus {
  allowed
  blocked
}

enum IdentityClaimStatus {
  active
  unclaimed
  pending
}

enum CustomerKind {
  personal
  organization
}

enum MembershipRole {
  owner
  member
  viewer
}

enum AgentBindingProvisionStatus {
  pending
  ready
  error
}

enum ParkedInboundStatus {
  queued
  processing
  drained
  failed
}

enum ChannelOwnershipKind {
  customer
  shared
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Tenant {
  id        String     @id
  slug      String     @unique
  name      String
  settings  Json       @default("{}")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  members       Member[]
  sessions      Session[]
  channels      Channel[]
  endUsers      EndUser[]
  clawscaleUsers ClawscaleUser[]
  auditLogs     AuditLog[]
  aiBackends    AiBackend[]
  deliveryRoutes DeliveryRoute[]

  @@map("tenants")
}

/// Internal staff who manage the bot (owner/admin/viewers).
model Member {
  id           String     @id
  tenantId     String     @map("tenant_id")
  email        String
  name         String
  passwordHash String     @map("password_hash")
  role         MemberRole @default(member)
  isActive     Boolean    @default(true) @map("is_active")
  lastActiveAt DateTime?  @map("last_active_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions  Session[]
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("members")
}

model AdminAccount {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  mfaSecret    String?  @map("mfa_secret")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_accounts")
}

model Session {
  id        String   @id
  memberId  String   @map("member_id")
  tenantId  String   @map("tenant_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([tenantId])
  @@map("sessions")
}

model Channel {
  id                   String        @id
  tenantId             String        @map("tenant_id")
  type                 ChannelType
  scope                ChannelScope  @default(tenant_shared)
  ownershipKind        ChannelOwnershipKind @default(customer) @map("ownership_kind")
  customerId           String?       @map("customer_id")
  agentId              String?       @map("agent_id")
  ownerClawscaleUserId String?       @map("owner_clawscale_user_id")
  activeLifecycleKey   String?       @unique @map("active_lifecycle_key")
  name                 String
  status               ChannelStatus @default(disconnected)
  config               Json          @default("{}")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer           Customer?       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  sharedAgent        Agent?          @relation(fields: [agentId], references: [id], onDelete: Restrict)
  ownerClawscaleUser ClawscaleUser? @relation(fields: [ownerClawscaleUserId], references: [id], onDelete: SetNull)
  externalIdentities ExternalIdentity[]
  parkedInbounds    ParkedInbound[]
  conversations     Conversation[]
  endUsers          EndUser[]
  deliveryRoutes    DeliveryRoute[]

  @@index([tenantId])
  @@index([customerId])
  @@index([agentId])
  @@index([ownerClawscaleUserId])
  @@map("channels")
}

/// External users who chat with the bot via social channels.
/// Identified by (tenantId, channelId, externalId) — the platform's user ID.
/// Can be anonymous (no name/email) until the bot or owner enriches the record.
model EndUser {
  id         String        @id
  tenantId   String        @map("tenant_id")
  channelId  String        @map("channel_id")
  externalId String        @map("external_id") // platform-native user ID
  name       String?
  email      String?
  metadata   Json          @default("{}")
  status     EndUserStatus @default(allowed)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  /// When set, this EndUser defers to the primary EndUser for cross-channel identity.
  linkedTo      String?   @map("linked_to")
  clawscaleUserId String? @map("clawscale_user_id")

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel         Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  linkedPrimary   EndUser?       @relation("EndUserLink", fields: [linkedTo], references: [id], onDelete: SetNull)
  linkedFrom      EndUser[]      @relation("EndUserLink")
  clawscaleUser   ClawscaleUser? @relation(fields: [clawscaleUserId], references: [id], onDelete: SetNull)
  conversations   Conversation[]
  activeBackends  EndUserBackend[]
  linkCodes       LinkCode[]
  deliveryRoutes  DeliveryRoute[]

  @@unique([tenantId, channelId, externalId])
  @@index([clawscaleUserId])
  @@index([tenantId])
  @@map("end_users")
}

model ClawscaleUser {
  id            String   @id
  tenantId      String   @map("tenant_id")
  cokeAccountId String   @map("coke_account_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      Customer    @relation(fields: [cokeAccountId], references: [id], onDelete: Cascade)
  channels      Channel[]
  endUsers      EndUser[]
  deliveryRoutes DeliveryRoute[]
  conversations Conversation[]

  @@unique([tenantId, cokeAccountId])
  @@unique([cokeAccountId])
  @@index([tenantId])
  @@map("clawscale_users")
}

model Identity {
  id           String              @id @default(uuid())
  email        String?             @unique
  phone        String?
  displayName  String              @map("display_name")
  passwordHash String?             @map("password_hash")
  claimStatus  IdentityClaimStatus @default(active) @map("claim_status")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  memberships Membership[]
  calendarImportRuns CalendarImportRun[]

  @@map("identities")
}

model Customer {
  id           String       @id
  kind         CustomerKind @default(personal)
  displayName  String       @map("display_name")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  memberships        Membership[]
  channels           Channel[]
  agentBindings      AgentBinding[]
  externalIdentities ExternalIdentity[]
  calendarImportRuns CalendarImportRun[]
  clawscaleUser      ClawscaleUser?
  subscriptions      Subscription[]

  @@map("customers")
}

model Membership {
  id         String         @id @default(uuid())
  identityId String         @map("identity_id")
  customerId String         @map("customer_id")
  role       MembershipRole @default(owner)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([identityId, customerId])
  @@index([identityId])
  @@index([customerId])
  @@map("memberships")
}

model Agent {
  id         String   @id @default(uuid())
  slug       String   @unique
  name       String
  endpoint   String
  authToken  String   @map("auth_token")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  bindings       AgentBinding[]
  sharedChannels Channel[]

  @@map("agents")
}

model AgentBinding {
  id                 String                       @id @default(uuid())
  customerId         String                       @map("customer_id")
  agentId            String                       @map("agent_id")
  provisionStatus    AgentBindingProvisionStatus @default(pending) @map("provision_status")
  provisionAttempts  Int                         @default(0) @map("provision_attempts")
  provisionLastError String?                      @map("provision_last_error")
  provisionUpdatedAt DateTime                     @default(now()) @map("provision_updated_at")
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  agent    Agent    @relation(fields: [agentId], references: [id], onDelete: Restrict)

  @@unique([customerId])
  @@index([agentId])
  @@map("agent_bindings")
}

model ExternalIdentity {
  id                 String   @id @default(uuid())
  provider           String
  identityType       String   @map("identity_type")
  identityValue      String   @map("identity_value")
  customerId         String   @map("customer_id")
  firstSeenChannelId String   @map("first_seen_channel_id")
  firstSeenAt        DateTime @default(now()) @map("first_seen_at")
  lastSeenAt         DateTime @default(now()) @map("last_seen_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  firstSeenChannel Channel  @relation(fields: [firstSeenChannelId], references: [id], onDelete: Restrict)

  @@unique([provider, identityType, identityValue])
  @@index([customerId])
  @@map("external_identities")
}

model ParkedInbound {
  id            String             @id @default(uuid())
  channelId     String             @map("channel_id")
  provider      String
  identityType  String             @map("identity_type")
  identityValue String             @map("identity_value")
  payload       Json
  status        ParkedInboundStatus @default(queued)
  attempts      Int                @default(0)
  lastError     String?            @map("last_error")
  drainedAt     DateTime?          @map("drained_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, status, createdAt])
  @@index([status, createdAt])
  @@index([provider, identityType, identityValue])
  @@map("parked_inbounds")
}

model Subscription {
  id              String   @id @default(cuid())
  customerId      String   @map("customer_id")
  stripeSessionId String   @unique @map("stripe_session_id")
  amountPaid      Int      @map("amount_paid")
  currency        String   @default("usd")
  startsAt        DateTime @map("starts_at")
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([customerId, expiresAt])
  @@map("subscriptions")
}

model EndUserBackend {
  /// Compatibility survivor: per-end-user backend selections still read from
  /// gateway storage until agent storage owns backend selection state.
  endUserId String   @map("end_user_id")
  backendId String   @map("backend_id")
  addedAt   DateTime @default(now()) @map("added_at")

  endUser   EndUser   @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  backend   AiBackend @relation(fields: [backendId], references: [id], onDelete: Cascade)

  @@id([endUserId, backendId])
  @@index([endUserId])
  @@index([backendId])
  @@map("end_user_backends")
}

model Conversation {
  /// Compatibility survivor: reduced to the route-binding minimum while delivery
  /// route cutover still depends on gateway conversation identifiers.
  id        String   @id
  tenantId  String   @map("tenant_id")
  channelId String   @map("channel_id")
  endUserId String   @map("end_user_id")
  clawscaleUserId String? @map("clawscale_user_id")
  businessConversationKey String? @map("business_conversation_key")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  channel  Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  endUser  EndUser    @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  clawscaleUser ClawscaleUser? @relation(fields: [clawscaleUserId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([tenantId])
  @@index([endUserId])
  @@index([clawscaleUserId])
  @@unique([clawscaleUserId, businessConversationKey])
  @@map("conversations")
}

model DeliveryRoute {
  tenantId                String   @map("tenant_id")
  cokeAccountId           String   @map("coke_account_id")
  businessConversationKey String   @map("business_conversation_key")
  channelId               String   @map("channel_id")
  endUserId               String   @map("end_user_id")
  externalEndUserId       String   @map("external_end_user_id")
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel       Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  endUser       EndUser       @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  clawscaleUser ClawscaleUser @relation(fields: [cokeAccountId], references: [cokeAccountId], onDelete: Cascade)

  @@id([cokeAccountId, businessConversationKey])
  @@index([tenantId])
  @@index([channelId])
  @@index([endUserId])
  @@map("delivery_routes")
}

model Message {
  /// Compatibility survivor: assistant message attribution still reads backend
  /// IDs from gateway history until agent storage owns transcript history.
  id             String      @id
  conversationId String      @map("conversation_id")
  role           MessageRole
  content        String
  /// Which AI backend generated this assistant message (null for user messages & ClawScale agent)
  backendId      String?     @map("backend_id")
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  backend      AiBackend?   @relation(fields: [backendId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@map("messages")
}

model OutboundDelivery {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  channelId      String   @map("channel_id")
  idempotencyKey String   @map("idempotency_key")
  payload        Json
  status         String
  error          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([idempotencyKey])
  @@index([tenantId])
  @@index([channelId])
  @@map("outbound_deliveries")
}

model CalendarImportRun {
  id                   String   @id @default(cuid())
  customerId           String   @map("customer_id")
  identityId           String   @map("identity_id")
  targetConversationId String   @map("target_conversation_id")
  targetCharacterId    String   @map("target_character_id")
  provider             String
  triggerSource        String   @map("trigger_source")
  status               String
  providerAccountEmail String?  @map("provider_account_email")
  importedCount        Int      @default(0) @map("imported_count")
  skippedCount         Int      @default(0) @map("skipped_count")
  failedCount          Int      @default(0) @map("failed_count")
  errorSummary         String?  @map("error_summary")
  startedAt            DateTime @default(now()) @map("started_at")
  finishedAt           DateTime? @map("finished_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([customerId, startedAt])
  @@index([identityId, startedAt])
  @@map("calendar_import_runs")
}

model AiBackend {
  /// Compatibility survivor: backend registry still powers bridge delivery,
  /// message attribution, and legacy backend selection during cutover.
  id        String   @id
  tenantId  String   @map("tenant_id")
  /// Human-readable name shown to end-users in the selection menu
  name      String
  /// Provider type: openai | anthropic | openrouter | pulse | openclaw | custom
  type      String
  /// Provider-specific config: { apiKey?, model?, baseUrl?, pulseApiUrl?, openClawUrl? }
  config    Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// True for the built-in ClawScale default agent (one per tenant, cannot be deleted)
  isDefault     Boolean  @default(false) @map("is_default")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endUsers      EndUserBackend[]
  messages      Message[]

  @@index([tenantId])
  @@map("ai_backends")
}

model AuditLog {
  id         String   @id
  tenantId   String   @map("tenant_id")
  memberId   String?  @map("member_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("audit_logs")
}

/// Short-lived codes for cross-channel account linking.
model LinkCode {
  id        String   @id @default(cuid())
  code      String   @unique
  tenantId  String   @map("tenant_id")
  endUserId String   @map("end_user_id")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  endUser EndUser @relation(fields: [endUserId], references: [id], onDelete: Cascade)

  @@index([code, used])
  @@map("link_codes")
}

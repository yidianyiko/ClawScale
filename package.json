{
  "name": "clawscale",
  "version": "0.1.0",
  "private": true,
  "description": "ClawScale customer and shared-channel gateway for Coke/Kap",
  "scripts": {
    "dev": "pnpm --parallel -r --filter \"!@clawscale/cli-bridge\" dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:push": "pnpm --filter @clawscale/api db:push",
    "db:migrate": "pnpm --filter @clawscale/api db:migrate",
    "db:studio": "pnpm --filter @clawscale/api db:studio"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
